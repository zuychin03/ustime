# @nuxtjs/supabase reads these names:
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_KEY="your-anon-public-key"
NUXT_SUPABASE_SECRET_KEY="your-service-role-secret-key"

# Postgres connection string for Drizzle migrations (Supabase session pooler).
DATABASE_URL="postgresql://postgres.YOUR-REF:[PASSWORD]@aws-REGION.pooler.supabase.com:5432/postgres"
